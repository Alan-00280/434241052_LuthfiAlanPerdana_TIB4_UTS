{
	"name": "helpdesk-ticketing",
	"version": "1.0.0",
	"description": "E-Ticketing Helpdesk berbasis Flutter yang akan digunakan untuk pelaporan, monitoring dan penyelesaian masalah IT atau layanan lainnya.",
	"main": "index.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"lint": "pnpx @biomejs/biome check",
		"lint:fix": "pnpx @biomejs/biome check --write --unsafe",
		"format": "pnpx @biomejs/biome format .",
		"format:fix": "pnpx @biomejs/biome format . --write",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,js}": [
			"pnpx @biomejs/biome check"
		]
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"hono": "^4.12.12",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pino-pretty": "^13.1.3"
	}
}
